# App origin
# Used by some server routes when they need to call back into the app.
NEXT_PUBLIC_BASE_URL=http://localhost:5001

# IBKR Client Portal Gateway
IBKR_GATEWAY_URL=https://localhost:5050
IBKR_BASE_PATH=/v1/api
IBKR_MOCK_MODE=false
IBKR_ACCOUNT_ID=

# Optional IBKR daemon tuning
IBKR_KEEPALIVE_INTERVAL_MS=55000
IBKR_LIVE_FEED_INTERVAL_MS=1000

# Optional operator name for futures/FOP order placement
IBKR_EXT_OPERATOR=

# App-owned market data credentials
# FRED currently has a code fallback, but setting this explicitly is cleaner.
FRED_API_KEY=
EIA_API_KEY=

# OpenBB sidecar runtime
OPENBB_SIDECAR_HOST=127.0.0.1
OPENBB_SIDECAR_PORT=5052

# Optional: override only if the repo-local defaults do not apply.
OPENBB_SIDECAR_PYTHON=.runtime/openbb-venv/bin/python
OPENBB_SIDECAR_SCRIPT=scripts/openbb_sidecar.py

# Optional: use this instead of host/port if pointing at an existing sidecar.
# OPENBB_SIDECAR_URL=http://127.0.0.1:5052

# Optional TLS/cert override for Python/OpenBB requests on some macOS setups.
SSL_CERT_FILE=
# REQUESTS_CA_BUNDLE=
# CURL_CA_BUNDLE=

# Note:
# OpenBB provider credentials such as fred/eia/fmp/intrinio are typically stored
# in ~/.openbb_platform/user_settings.json, not in this repo env file.
